# Images are built by GitHub Actions and pulled from GHCR.
API_IMAGE=ghcr.io/beterer/doomschooling-api:latest
WEB_IMAGE=ghcr.io/beterer/doomschooling-web:latest

# AI provider. Keep real keys only in the VPS .env file.
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=replace-me
OPENROUTER_MODEL=deepseek/deepseek-v4-flash
GEMINI_API_KEY=

# Clerk production instance for doomschooling.org.
CLERK_PUBLISHABLE_KEY=pk_live_replace_me
CLERK_SECRET_KEY=sk_live_replace_me

# Comma-separated, case-insensitive list. Only users with a verified matching
# Clerk email can call the feed generation endpoints.
GENERATION_EMAIL_ALLOWLIST=owner@example.com

# Existing remotely-managed Cloudflare Tunnel connector token.
CLOUDFLARE_TUNNEL_TOKEN=replace-me
