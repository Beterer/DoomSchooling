DATABASE_URL=postgresql://postgres:postgres@localhost:5432/learnfeed
LLM_PROVIDER=openrouter      # openrouter | gemini | mock
OPENROUTER_API_KEY=          # required if LLM_PROVIDER=openrouter
OPENROUTER_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_SITE_URL=http://localhost:5173
DEV_AUTH_BYPASS=false       # local API only; never enabled in production
VITE_DEV_AUTH_BYPASS=false  # local web only; never enabled in production
GEMINI_API_KEY=              # required if LLM_PROVIDER=gemini
ANTHROPIC_API_KEY=           # only needed if LLM_PROVIDER=claude
OPENAI_API_KEY=              # only needed if LLM_PROVIDER=openai
CLERK_PUBLISHABLE_KEY=               # from Clerk dashboard (backend)
CLERK_SECRET_KEY=                    # from Clerk dashboard (backend)
VITE_CLERK_PUBLISHABLE_KEY=          # from Clerk dashboard (frontend, same key as CLERK_PUBLISHABLE_KEY)

# Existing named Cloudflare Tunnel connector token. Needed only by tunnel.sh or
# when provisioning production; never commit the real token.
CLOUDFLARE_TUNNEL_TOKEN=
